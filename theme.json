{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"padding": true,
			"margin": true
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Crimson Text', Georgia, 'Times New Roman', serif",
					"name": "Crimson Text",
					"slug": "crimson-text"
				},
				{
					"fontFamily": "'EB Garamond', Georgia, 'Times New Roman', serif",
					"name": "EB Garamond",
					"slug": "eb-garamond"
				},
				{
					"fontFamily": "'Spectral', Georgia, 'Times New Roman', serif",
					"name": "Spectral",
					"slug": "spectral"
				},
				{
					"fontFamily": "'Libre Baskerville', Georgia, 'Times New Roman', serif",
					"name": "Libre Baskerville",
					"slug": "libre-baskerville"
				},
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Font",
					"slug": "system-font"
				}
			],
			"fontSizes": [
				{
					"name": "Extra Small",
					"slug": "xs",
					"size": "0.72rem"
				},
				{
					"name": "Small",
					"slug": "sm",
					"size": "0.9rem"
				},
				{
					"name": "Medium",
					"slug": "md",
					"size": "1.125rem"
				},
				{
					"name": "Large",
					"slug": "lg",
					"size": "1.406rem"
				},
				{
					"name": "Extra Large",
					"slug": "xl",
					"size": "1.758rem"
				},
				{
					"name": "2X Large",
					"slug": "2xl",
					"size": "2.197rem"
				},
				{
					"name": "3X Large",
					"slug": "3xl",
					"size": "2.747rem"
				},
				{
					"name": "4X Large",
					"slug": "4xl",
					"size": "3.433rem"
				}
			],
			"lineHeight": true,
			"customLineHeight": true,
			"dropCap": false
		},
		"color": {
			"palette": [
				{
					"name": "Background",
					"slug": "background",
					"color": "#FAFAF8"
				},
				{
					"name": "Surface",
					"slug": "surface",
					"color": "#FFFFFF"
				},
				{
					"name": "Text",
					"slug": "text",
					"color": "#2C2C2C"
				},
				{
					"name": "Text Light",
					"slug": "text-light",
					"color": "#666666"
				},
				{
					"name": "Primary",
					"slug": "primary",
					"color": "#2C2C2C"
				},
				{
					"name": "Accent",
					"slug": "accent",
					"color": "#8B7355"
				},
				{
					"name": "Border",
					"slug": "border",
					"color": "#E5E5E5"
				}
			],
			"gradients": [],
			"duotone": [],
			"custom": true,
			"customDuotone": false,
			"customGradient": false,
			"defaultGradients": false,
			"defaultPalette": false
		},
		"custom": {
			"spacing": {
				"unit": "8px",
				"xs": "8px",
				"sm": "16px",
				"md": "24px",
				"lg": "32px",
				"xl": "48px",
				"2xl": "64px",
				"3xl": "96px"
			},
			"lineHeight": {
				"tight": 1.2,
				"normal": 1.5,
				"relaxed": 1.8,
				"loose": 2.0,
				"poetry": 2.2
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--crimson-text)",
			"fontSize": "var(--wp--preset--font-size--md)",
			"lineHeight": "1.8"
		},
		"spacing": {
			"padding": {
				"top": "0px",
				"right": "0px",
				"bottom": "0px",
				"left": "0px"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--4-xl)",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3-xl)",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2-xl)",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"lineHeight": "1.2"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)",
					"lineHeight": "1.2"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--md)",
					"lineHeight": "1.2",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"spacing": {
					"margin": {
						"bottom": "24px"
					}
				}
			},
			"core/heading": {
				"spacing": {
					"margin": {
						"bottom": "24px"
					}
				}
			},
			"core/quote": {
				"border": {
					"width": "0 0 0 4px",
					"color": "var(--wp--preset--color--border)",
					"style": "solid"
				},
				"spacing": {
					"padding": {
						"left": "32px"
					},
					"margin": {
						"top": "32px",
						"bottom": "32px"
					}
				},
				"typography": {
					"fontStyle": "italic"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--surface)",
					"text": "var(--wp--preset--color--text)"
				},
				"border": {
					"width": "1px",
					"color": "var(--wp--preset--color--border)",
					"style": "solid",
					"radius": "4px"
				},
				"spacing": {
					"padding": "24px"
				},
				"typography": {
					"fontFamily": "'Courier New', Courier, monospace"
				}
			},
			"core/preformatted": {
				"color": {
					"background": "var(--wp--preset--color--surface)",
					"text": "var(--wp--preset--color--text)"
				},
				"border": {
					"width": "1px",
					"color": "var(--wp--preset--color--border)",
					"style": "solid",
					"radius": "4px"
				},
				"spacing": {
					"padding": "24px"
				},
				"typography": {
					"fontFamily": "inherit",
					"fontSize": "inherit",
					"lineHeight": "2.2"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
